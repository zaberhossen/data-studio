# ── Application database (Drizzle/Postgres) ────────────────────────────────
# This is Data Studio's OWN metadata store (users, orgs, dashboards, encrypted
# data-source secrets, share links). It is NOT a customer data source.
# Copy this file to `.env.local` and fill in real values.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/data_studio

# ── Authentication (Auth.js / NextAuth v5) ─────────────────────────────────
# Secret used to sign/encrypt the session JWT. Generate with:
#   npx auth secret     (or)   openssl rand -base64 32
AUTH_SECRET=

# ── Credential encryption at rest ──────────────────────────────────────────
# Base64-encoded 32-byte key used to seal data-source secrets (AES-256-GCM).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_STUDIO_ENC_KEY=

# Key rotation (optional): a versioned keyring, highest version = current.
# When set, this takes precedence over DATA_STUDIO_ENC_KEY.
#   DATA_STUDIO_ENC_KEYS=1:<base64key>,2:<base64key>

# ── Server data limits (optional; defaults shown) ──────────────────────────
# DATA_STUDIO_ROW_CAP=100000
# DATA_STUDIO_QUERY_TIMEOUT_MS=30000
